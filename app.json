{
  "expo": {
    "name": "Pothole Alert",
    "slug": "pothole-alert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "pothole-alert",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B7A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.potholealert.app"
    },
    "android": {
      "package": "com.potholealert.app",
      "adaptiveIcon": {
        "backgroundColor": "#1A6B7A",
        "foregroundImage": "./assets/images/splash-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKeyForPreventingCrash12345678"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Pothole Alert to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5319821-9103-470b-b651-b266a84dd41f"
      }
    }
  }
}